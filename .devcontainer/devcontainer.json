{
  "name": "Rust Power User",
  "image": "mcr.microsoft.com/devcontainers/rust:latest",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "skellock.just",
        "fill-labs.dependi",
        "serayuzgur.crates",
        "usernamehw.errorlens",
        "eamodio.gitlens",
        "ms-vscode.hexeditor"
      ],
      "settings": {
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.checkOnSave": true,
        "rust-analyzer.cargo.allFeatures": true,
        "editor.formatOnSave": true,
        "editor.inlayHints.enabled": "on",
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "rust-analyzer.procMacro.enable": true
      }
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "nonFreePackages": true
    }
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y just ripgrep fd-find bat git-delta hyperfine valgrind lldb && cargo install --locked cargo-binstall && cargo binstall -y --locked cargo-nextest cargo-edit cargo-watch cargo-expand cargo-outdated cargo-audit cargo-udeps cargo-semver-checks cargo-flamegraph cargo-llvm-lines cargo-tarpaulin cargo-instruments && rustup component add rustfmt clippy rust-src rust-analyzer && echo '🚀 Rust Power User Environment loaded successfully!'",

  "postStartCommand": "rustc --version && cargo --version && cargo nextest --version",

  "containerEnv": {
    "CARGO_INCREMENTAL": "1",
    "RUST_BACKTRACE": "1",
    "RUSTFLAGS": "-D warnings",
    "CARGO_TERM_COLOR": "always"
  },

  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/.cargo/registry,target=/usr/local/cargo/registry,type=bind,consistency=cached"
  ]
}